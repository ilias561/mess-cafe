# Web3Forms (https://web3forms.com)
# Create a free account, generate an access key, and paste it below.
NEXT_PUBLIC_WEB3FORMS_KEY=your_access_key_here

# CallMeBot WhatsApp API (https://www.callmebot.com/blog/free-api-whatsapp-messages/)
# Message the bot on WhatsApp once to receive your phone-specific API key.
NEXT_PUBLIC_CALLMEBOT_PHONE=306900000000
NEXT_PUBLIC_CALLMEBOT_KEY=your_callmebot_key_here

# Direct WhatsApp contact number used for CTA links and floating button (international format, no +).
NEXT_PUBLIC_WHATSAPP_NUMBER=306900000000

# Brevo newsletter popup (contacts-only API key, restricted and rotatable).
NEXT_PUBLIC_BREVO_API_KEY=
NEXT_PUBLIC_BREVO_LIST_ID=
